NEXTAUTH_SECRET=replace-with-long-random-secret
# Use either KV REST envs OR REDIS_URL
KV_REST_API_URL=your-vercel-kv-rest-url
KV_REST_API_TOKEN=your-vercel-kv-rest-token
REDIS_URL=redis://default:password@host:port
BLOB_READ_WRITE_TOKEN=your-vercel-blob-read-write-token

# JSON array of admin users; use bcrypt hashes (escape $ as \$ in .env files)
CATCHY_ADMIN_USERS_JSON=[{"email":"admin@example.com","name":"Primary Admin","role":"admin","password_hash":"\$2b\$12\$replace-with-bcrypt-hash","totp_secret":""}]

# Optional alternative to avoid escaping issues: base64-encoded JSON value
# CATCHY_ADMIN_USERS_JSON_B64=

# Optional: comma-separated IP allowlist for admin routes
# CATCHY_ADMIN_IP_ALLOWLIST=203.0.113.10,198.51.100.22

# Optional: login lockout tuning
# CATCHY_ADMIN_LOGIN_MAX_ATTEMPTS=5
# CATCHY_ADMIN_LOGIN_WINDOW_MINUTES=15
# CATCHY_ADMIN_LOGIN_LOCK_MINUTES=30
