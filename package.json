{
  "name": "catchy-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "encode:hero-video": "ffmpeg -i public/videos/catchy-hero-source.mp4 -c:v libx264 -pix_fmt yuv420p -profile:v high -level 4.1 -c:a aac -b:a 128k -movflags +faststart public/videos/catchy-hero.mp4",
    "split:testimonial-avatars": "node scripts/split-testimonial-avatars.mjs",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "start-server-and-test \"npm run dev -- --port 3000 --hostname 127.0.0.1\" http://127.0.0.1:3000 \"playwright test --workers=1\""
  },
  "dependencies": {
    "@vercel/blob": "^2.3.1",
    "@vercel/kv": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "otplib": "^13.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "sharp": "^0.34.5",
    "start-server-and-test": "^2.1.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
